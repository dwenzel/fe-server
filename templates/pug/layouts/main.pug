doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title #{meta.title} - Frontend Server
    if meta.description
      meta(name="description" content=meta.description)
    if meta.keywords
      meta(name="keywords" content=meta.keywords.join(', '))
    style.
      body {
        font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
        line-height: 1.6;
        color: #333;
        max-width: 1200px;
        margin: 0 auto;
        padding: 1rem;
      }
      header {
        border-bottom: 1px solid #eee;
        padding-bottom: 1rem;
        margin-bottom: 2rem;
      }
      footer {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid #eee;
        font-size: 0.9rem;
        color: #666;
      }
      h1, h2, h3 {
        color: #036;
      }
      .item {
        margin-bottom: 2rem;
        padding: 1rem;
        border: 1px solid #eee;
        border-radius: 4px;
      }
      .metadata {
        font-size: 0.9rem;
        color: #666;
        margin-bottom: 1rem;
      }
  body
    header
      h1 Frontend Server
      nav
        a(href="/api/v1/pages") Pages
        |  | 
        a(href="/api/v1/items") Items
    
    main
      block content
    
    footer
      p Rendered with Pug - Frontend Server &copy; #{new Date().getFullYear()}