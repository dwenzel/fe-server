{{!-- Default error template for Handlebars --}}
<div class="error">
  <h1>Error {{statusCode}}</h1>
  <p>{{message}}</p>
  
  {{#if stack}}
  <div class="error-details">
    <h3>Error Details:</h3>
    <pre>{{stack}}</pre>
  </div>
  {{/if}}
  
  <div class="actions">
    <a href="/frontend/pages">Back to Pages</a>
  </div>
</div>