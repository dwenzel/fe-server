# Database Configuration
# Choose the database adapter type (memory, mongodb, postgresql, mysql)
DB_TYPE=memory

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/frontend-server

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=frontend_server
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSL=false

# MySQL Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DB=frontend_server
MYSQL_USER=root
MYSQL_PASSWORD=mysql

# Server Configuration
PORT=8080
HOST=0.0.0.0

# API Configuration
API_VERSION=v1
API_KEY=test-api-key

# Logging Configuration
LOG_LEVEL=info